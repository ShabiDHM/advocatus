# FILE: Caddyfile
# PHOENIX PROTOCOL - FINAL & COMPLETE INFRASTRUCTURE DEFINITION

advocatus-prod-api.duckdns.org {
    tls shabanbala@gmail.com

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
    }

    # --- Named Matchers for Explicit Routing ---

    # @websockets: Matches WebSocket upgrade requests.
    @websockets {
        path /api/v1/comms/*
        header Connection *Upgrade*
        header Upgrade websocket
    }

    # @options: Matches CORS preflight OPTIONS requests.
    @options {
        method OPTIONS
    }

    # @api: A catch-all for any other standard API traffic.
    @api {
        path /api/*
    }

    # --- Routing Logic ---

    # 1. Handle CORS preflight requests first.
    # Respond with 204 No Content and permissive CORS headers.
    # This efficiently tells the browser the actual request is allowed.
    respond @options 204 {
        header Access-Control-Allow-Origin "https://advocatus-ai.vercel.app, https://advocatus-ai-*.vercel.app"
        header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "*"
        header Access-Control-Allow-Credentials "true"
        header Access-Control-Max-Age "86400"
    }

    # 2. Handle WebSocket traffic.
    # Proxy to the backend, forwarding necessary upgrade headers.
    reverse_proxy @websockets backend:8000 {
        header_up +Connection {http.request.header.Connection}
        header_up +Upgrade {http.request.header.Upgrade}
    }

    # 3. Handle all other API traffic.
    # Proxy standard HTTP requests to the backend.
    reverse_proxy @api backend:8000
}