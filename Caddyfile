# FILE: Caddyfile
# PHOENIX PROTOCOL - DEFINITIVE INFRASTRUCTURE FIX

advocatus-prod-api.duckdns.org {
    # TLS and standard security headers remain unchanged.
    tls shabanbala@gmail.com

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
    }

    # --- Named Matchers for Explicit Routing ---

    # @websockets matcher:
    # Identifies a request as a WebSocket handshake if it has an Upgrade header
    # with the value 'websocket'. This is the most reliable method.
    @websockets {
        path /api/v1/comms/*
        header Connection *Upgrade*
        header Upgrade websocket
    }

    # @api matcher:
    # A catch-all for any other traffic directed to the API.
    @api {
        path /api/*
    }

    # --- Routing Logic ---
    
    # Route WebSocket traffic to the backend, explicitly forwarding the
    # necessary headers to complete the protocol upgrade handshake.
    reverse_proxy @websockets backend:8000 {
        # These headers are required for the WebSocket handshake.
        header_up +Connection {http.request.header.Connection}
        header_up +Upgrade {http.request.header.Upgrade}
    }

    # Route all other API traffic to the backend as standard HTTP requests.
    reverse_proxy @api backend:8000
}